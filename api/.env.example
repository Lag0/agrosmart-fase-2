# AgroSmart API Environment Configuration

# Storage
AGROSMART_UPLOADS_DIR=/data/uploads

# OpenRouter API (for AI classification)
AGROSMART_OPENROUTER_API_KEY=your_openrouter_api_key_here

# API Version
AGROSMART_API_VERSION=1.0.0

# CORS (comma-separated)
AGROSMART_CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Analysis timeout (seconds)
AGROSMART_ANALYSIS_TIMEOUT_S=10.0

# Classification settings
AGROSMART_CLASSIFY_TIMEOUT_S=10.0
AGROSMART_CLASSIFY_MAX_TOKENS=300
AGROSMART_CACHE_TTL_S=3600
