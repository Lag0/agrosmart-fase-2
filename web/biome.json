{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/.next",
      "!**/node_modules",
      "!**/node_modules",
      "!**/.agents",
      "!**/.agents",
      "!**/.pi",
      "!**/.pi",
      "!**/.claude",
      "!**/.claude"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
